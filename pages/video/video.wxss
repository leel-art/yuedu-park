/* pages/video/video.wxss —— 视频介绍页样式 */

.page-video {
  background: #000;
  min-height: 100vh;
  color: #fff;
}

/* ===== 状态栏 ===== */
.status-bar {
  background: #000;
}

/* ===== 顶部导航栏 ===== */
.video-nav {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #fff;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.15);
}

.back-icon {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 300;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
}

.nav-placeholder {
  width: 100rpx;
}

/* ===== 视频播放器 ===== */
.player-wrap {
  width: 100%;
  background: #000;
}

.video-player {
  width: 100%;
  height: 480rpx;
}

/* 封面占位 */
.cover-poster {
  width: 100%;
  height: 100%;
  position: relative;
}

.poster-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.poster-center {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.3);
}

.play-btn-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.3);
}

.play-triangle {
  width: 0;
  height: 0;
  border-left: 28rpx solid var(--primary);
  border-top: 18rpx solid transparent;
  border-bottom: 18rpx solid transparent;
  margin-left: 6rpx;
}

.play-label {
  color: #fff;
  font-size: 26rpx;
  margin-top: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

/* ===== 视频信息卡片 ===== */
.video-info {
  background: #1a1a1a;
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius-lg);
  padding: 28rpx;
}

.vi-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.vi-spot-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.vi-spot-subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

.vi-duration {
  background: var(--accent);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.vi-duration-text {
  font-size: 22rpx;
}

/* 进度条 */
.vi-progress {
  margin-bottom: 20rpx;
}

.vi-bar {
  height: 4rpx;
  background: #333;
  border-radius: 2rpx;
  overflow: hidden;
}

.vi-fill {
  height: 100%;
  background: var(--primary-light);
  border-radius: 2rpx;
  transition: width 0.3s;
}

/* 简介 */
.vi-desc {
  border-top: 1rpx solid #333;
  padding-top: 20rpx;
}

.vi-desc-label {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 10rpx;
}

.vi-desc-text {
  font-size: 26rpx;
  color: #bbb;
  line-height: 1.7;
}

/* ===== 操作按钮 ===== */
.video-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 24rpx;
}

.va-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: var(--radius);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.va-btn.primary {
  background: var(--primary);
  color: #fff;
}

.va-btn.primary:active {
  background: var(--primary-dark);
}

.va-btn.outline {
  background: transparent;
  color: var(--primary-light);
  border: 2rpx solid #333;
}

/* ===== 扫码标记 ===== */
.scan-marker {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 28rpx 24rpx;
  padding: 20rpx;
  background: rgba(76, 175, 80, 0.15);
  border-radius: var(--radius);
  border: 1rpx solid rgba(76, 175, 80, 0.3);
}

.scan-icon {
  font-size: 28rpx;
}

.scan-text {
  font-size: 24rpx;
  color: var(--primary-light);
}

/* ===== 底部 ===== */
.bottom-safe {
  height: 48rpx;
}

/* ===== 加载中 ===== */
.video-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #000;
  gap: 20rpx;
}

.loading-icon {
  font-size: 64rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #888;
}
