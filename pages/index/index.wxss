/* pages/index/index.wxss —— 首页样式 */

/* ===== 导航栏 ===== */
.nav-bar {
  background: linear-gradient(180deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx 20rpx;
}

.nav-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

.nav-subtitle {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
}

/* ===== Hero 大图 ===== */
.hero-section {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(0,0,0,0.2) 0%,
    rgba(0,0,0,0.05) 40%,
    rgba(0,0,0,0.5) 100%
  );
}

.hero-content {
  position: absolute;
  bottom: 48rpx;
  left: 32rpx;
  right: 32rpx;
  color: #fff;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  display: block;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.4);
  letter-spacing: 8rpx;
}

.hero-desc {
  font-size: 26rpx;
  display: block;
  margin-top: 12rpx;
  opacity: 0.9;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3);
}

.hero-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.hero-tag {
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(10rpx);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
}

/* ===== 景区简介卡片 ===== */
.intro-card {
  margin: -32rpx 24rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow);
  position: relative;
  z-index: 2;
}

.intro-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.intro-icon {
  font-size: 32rpx;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.intro-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.intro-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* ===== 天气卡片 ===== */
.weather-card {
  margin: 0 24rpx 16rpx;
  background: linear-gradient(135deg, #E8F5E9, #F1F8E9);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}
.weather-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.weather-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
}
.weather-location {
  font-size: 22rpx;
  color: var(--text-hint);
}
.weather-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.weather-icon {
  font-size: 64rpx;
}
.weather-temp {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--primary);
}
.weather-info {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.weather-forecast {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0,0,0,0.08);
}
.fc-item {
  flex: 1;
  text-align: center;
}
.fc-day {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 6rpx;
}
.fc-icon {
  font-size: 36rpx;
  display: block;
  margin-bottom: 4rpx;
}
.fc-temp {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ===== 分类筛选 ===== */
.category-section {
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 24rpx;
  border-radius: var(--radius);
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
  min-width: 120rpx;
}

.category-item.active {
  background: var(--primary);
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.25);
}

.category-item.active .category-name {
  color: #fff;
}

.category-icon {
  font-size: 32rpx;
}

.category-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ===== 景点列表 ===== */
.spot-section {
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
  margin-top: 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--text-hint);
}

.spot-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ===== 底部安全区 ===== */
.bottom-safe {
  height: 48rpx;
}

/* ===== 扫码提示浮窗 ===== */
.scan-tip {
  position: fixed;
  bottom: 48rpx;
  left: 48rpx;
  right: 48rpx;
  background: linear-gradient(135deg, #2E7D32, #1B5E20);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(46, 125, 50, 0.4);
  z-index: 200;
  animation: slideUp 0.4s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.scan-tip-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #fff;
  text-align: center;
}

.scan-tip-icon {
  font-size: 48rpx;
}

.scan-tip-text {
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-line;
}

.scan-tip-close {
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 8rpx;
}
