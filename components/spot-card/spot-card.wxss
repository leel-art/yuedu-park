/* components/spot-card/spot-card.wxss —— 景点卡片组件样式 */

.spot-card {
  background: #fff;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: all 0.2s;
}

.spot-card-hover {
  transform: scale(0.98);
  box-shadow: var(--shadow-hover);
}

/* ===== 封面图 ===== */
.card-cover {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 6rpx 18rpx;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(8rpx);
  color: #fff;
  font-size: 22rpx;
  border-radius: 16rpx;
}

.cover-video-badge {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.video-icon {
  color: #fff;
  font-size: 24rpx;
  margin-left: 3rpx;
}

/* ===== 信息区 ===== */
.card-body {
  padding: 24rpx 28rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.card-duration {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 14rpx;
  background: rgba(76, 175, 80, 0.08);
  border-radius: 16rpx;
}

.duration-icon {
  font-size: 20rpx;
}

.duration-text {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--accent);
  display: block;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

/* ===== 底部 ===== */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider);
}

.card-location {
  display: flex;
  align-items: center;
  gap: 4rpx;
  max-width: 60%;
}

.loc-icon {
  font-size: 20rpx;
  flex-shrink: 0;
}

.loc-text {
  font-size: 22rpx;
  color: var(--text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

.action-arrow {
  font-size: 32rpx;
  color: var(--primary);
  line-height: 1;
}
